rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return request.auth.token.role;
    }

    function hasRole(role) {
      return getUserRole() == role;
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('global_admin');
    }

    function isGlobalAdmin() {
      return hasRole('global_admin');
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Users
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isGlobalAdmin();
    }

    // Customers
    match /customers/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isGlobalAdmin();
    }

    // Tickets
    match /tickets/{docId} {
      allow read: if isAdmin()
                  || (isAuthenticated() && resource.data.assignedTechnicianId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (isAuthenticated()
                        && resource.data.assignedTechnicianId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));
      allow delete: if isGlobalAdmin();
    }

    // Service Reports
    match /serviceReports/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isGlobalAdmin()
                    || (isAdmin() && resource.data.locked != true);
      allow delete: if isGlobalAdmin();
    }

    // Mileage Logs
    match /mileageLogs/{docId} {
      allow read: if isAdmin()
                  || (isAuthenticated() && resource.data.technicianId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.technicianId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.technicianId == request.auth.uid;
      allow delete: if isGlobalAdmin();

      match /coordinates/{coordId} {
        allow read: if isAdmin()
                    || (isAuthenticated()
                        && get(/databases/$(database)/documents/mileageLogs/$(docId)).data.technicianId == request.auth.uid);
        allow create: if isAuthenticated()
                      && get(/databases/$(database)/documents/mileageLogs/$(docId)).data.technicianId == request.auth.uid;
      }
    }

    // Parts
    match /parts/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Conversations
    match /conversations/{docId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participantIds;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participantIds;

      match /messages/{msgId} {
        allow read: if isAuthenticated()
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(docId)).data.participantIds;
        allow create: if isAuthenticated()
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(docId)).data.participantIds;
        allow update: if isAuthenticated()
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(docId)).data.participantIds;
      }
    }

    // Settings (singleton documents)
    match /settings/{docId} {
      allow read: if isAdmin();
      allow write: if isGlobalAdmin();
    }
  }
}
